---
import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import { CheckImageUrl } from "../lib/utils";

import { contentfulClient } from "../lib/contentful";

import { ClientRouter } from "astro:transitions";

import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { documentToPlainTextString } from "@contentful/rich-text-plain-text-renderer";

import "@fontsource/aboreto";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";

const SeoGet = await contentfulClient.getEntries({
  content_type: "seo",
  limit: 1,
});

const seo_col = SeoGet.items.map((item) => {
  const { nomeDoSite, metaTitle, metaDescription, shareImage } = item.fields;
  return {
    nomeDoSite,
    metaTitle,
    metaDescription,
    shareImage,
  };
});

const seo = seo_col[0];

const { title_sufixo } = Astro.props;
const title = `${seo.nomeDoSite} ${title_sufixo ? " - " + title_sufixo : ""}`;

const MetaTitle = String(seo.metaTitle);

let MetaDescription = "";
if (seo.metaDescription) {
  if (typeof seo.metaDescription === "string") {
    MetaDescription = seo.metaDescription;
  } else {
    // Caso seja um campo Rich Text (Document) do Contentful
    MetaDescription = documentToPlainTextString(seo.metaDescription as any);
  }
}

const shareImg: any = seo.shareImage;
const MetaShareImage = shareImg?.fields?.file?.url ? CheckImageUrl(String(shareImg.fields.file.url)) : '';

const pageURL = Astro.url.href;

interface Props {
  title_sufixo?: string; // isso faz com que o título seja opcional
}
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Favicon e Manifest -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Kaledo Fotos" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={MetaDescription} />

    <!-- Open Graph -->
    <meta property="og:title" content={MetaTitle} />
    <meta property="og:description" content={MetaDescription} />
    <meta property="og:image" content={MetaShareImage} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={MetaTitle} />
    <meta name="twitter:description" content={MetaDescription} />
    <meta name="twitter:image" content={MetaShareImage} />


    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured Data for Local SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "PhotographyBusiness",
      "name": "KaledoFotos",
      "image": MetaShareImage || pageURL,
      "url": pageURL,
      "description": MetaDescription,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Itajaí",
        "addressRegion": "SC",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-26.9077",
        "longitude": "-48.6619"
      }
    })} />
    
  </head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-TN9KNLSC29"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-TN9KNLSC29');
</script>

  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }
</style>
