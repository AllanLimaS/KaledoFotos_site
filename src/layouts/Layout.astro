---
import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import { CheckImageUrl } from "../lib/utils";

import { contentfulClient } from "../lib/contentful";

import { ClientRouter } from "astro:transitions";

import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import { documentToPlainTextString } from "@contentful/rich-text-plain-text-renderer";

// Fontes carregadas via Google Fonts de forma assíncrona (S7)
// Remover imports @fontsource que eram bloqueantes

const SeoGet = await contentfulClient.getEntries({
  content_type: "seo",
  limit: 1,
});

const seo_col = SeoGet.items.map((item) => {
  const { nomeDoSite, metaTitle, metaDescription, shareImage } = item.fields;
  return {
    nomeDoSite,
    metaTitle,
    metaDescription,
    shareImage,
  };
});

const seo = seo_col[0];

const { title_sufixo } = Astro.props;
const title = `${seo.nomeDoSite} ${title_sufixo ? " - " + title_sufixo : ""}`;

const MetaTitle = String(seo.metaTitle);

let MetaDescription = "";
if (seo.metaDescription) {
  if (typeof seo.metaDescription === "string") {
    MetaDescription = seo.metaDescription;
  } else {
    // Caso seja um campo Rich Text (Document) do Contentful
    MetaDescription = documentToPlainTextString(seo.metaDescription as any);
  }
}

const shareImg: any = seo.shareImage;
const MetaShareImage = shareImg?.fields?.file?.url
  ? CheckImageUrl(String(shareImg.fields.file.url))
  : "";

const pageURL = Astro.url.href;

interface Props {
  title_sufixo?: string; // título da página (opcional)
  hero_preload_url?: string; // URL da primeira imagem hero para preload
}

const { hero_preload_url } = Astro.props;

let heroSrcset = "";
let heroSrc = "";
if (hero_preload_url) {
  const src640 = CheckImageUrl(hero_preload_url, 640);
  const src1024 = CheckImageUrl(hero_preload_url, 1024);
  const src1920 = CheckImageUrl(hero_preload_url, 1920);
  heroSrcset = `${src640} 640w, ${src1024} 1024w, ${src1920} 1920w`;
  heroSrc = src1920;
}
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Favicon e Manifest -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Kaledo Fotos" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={MetaDescription} />

    <!-- Open Graph -->
    <meta property="og:title" content={MetaTitle} />
    <meta property="og:description" content={MetaDescription} />
    <meta property="og:image" content={MetaShareImage} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={MetaTitle} />
    <meta name="twitter:description" content={MetaDescription} />
    <meta name="twitter:image" content={MetaShareImage} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preload da imagem hero para acelerar o LCP -->
    {
      hero_preload_url && (
        <link
          rel="preload"
          as="image"
          href={heroSrc}
          imagesrcset={heroSrcset}
          imagesizes="100vw"
          fetchpriority="high"
        />
      )
    }

    <!-- Google Fonts carregado de forma assíncrona (não bloqueia o render) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Aboreto&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Aboreto&display=swap"
      />
    </noscript>

    <!-- Structured Data for Local SEO -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "PhotographyBusiness",
        name: "KaledoFotos",
        image: MetaShareImage || pageURL,
        url: pageURL,
        description: MetaDescription,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Itajaí",
          addressRegion: "SC",
          addressCountry: "BR",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: "-26.9077",
          longitude: "-48.6619",
        },
      })}
    />
  </head>

  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <BackToTop />

    <!-- Google Analytics com defer — não bloqueia a thread principal -->
    <script defer src="https://www.googletagmanager.com/gtag/js?id=G-TN9KNLSC29"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-TN9KNLSC29");
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }
</style>
