---
---

<button
  id="back-to-top"
  class="fixed bottom-6 right-6 p-4 bg-preto text-white rounded-full shadow-xl opacity-0 pointer-events-none translate-y-5 transition-all duration-300 z-50 hover:bg-bege-escuro hover:scale-110"
  aria-label="Voltar ao topo"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("back-to-top");
    if (!btn) return;

    let isLightboxOpen = false;

    window.addEventListener("scroll", () => {
      if (window.scrollY > 300 && !isLightboxOpen) {
        btn.classList.remove("opacity-0", "pointer-events-none", "translate-y-5");
        btn.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
      } else {
        btn.classList.add("opacity-0", "pointer-events-none", "translate-y-5");
        btn.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
      }
    });

    window.addEventListener('lightboxOpened', () => {
      isLightboxOpen = true;
      btn.classList.add("opacity-0", "pointer-events-none", "translate-y-5");
      btn.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
    });

    window.addEventListener('lightboxClosed', () => {
      isLightboxOpen = false;
      if (window.scrollY > 300) {
        btn.classList.remove("opacity-0", "pointer-events-none", "translate-y-5");
        btn.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
      }
    });

    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
</script>
